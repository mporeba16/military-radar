# OpenSky Network — opcjonalne konto (bez konta: limit ~100 req/10min)
# Rejestracja: https://opensky-network.org/index.php?option=com_users&view=registration
# Zalogowani użytkownicy: ~4000 req/dzień
OPENSKY_USER=
OPENSKY_PASS=

# VAPID keys do Web Push (wygeneruj: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:twoj@email.com

# Dostępne w frontendzie (prefix VITE_)
VITE_VAPID_PUBLIC_KEY=
